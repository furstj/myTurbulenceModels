FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    p
    {
        solver           GAMG;
        tolerance        1e-6;
        relTol           0.01;
        maxIter          100;
        smoother         DICGaussSeidel;
    }

    "(U|k|omega|gammaInt|ReThetat)"
    {
        solver           PBiCGStab;
        preconditioner   DILU;
        tolerance        1e-6;
        relTol           0.01;
        minIter          1;
    }
}

SIMPLE
{
    nNonOrthogonalCorrectors 0;

    pRefCell        0;
    pRefValue       0;

    consistent      yes;
}

relaxationFactors
{
    fields
    {
        p               1.0;
    }
    equations
    {
        U               0.8;
        k               0.6;
        omega           0.6;
        ReThetat        0.6;
        gammaInt        0.6;
    }
}

cache
{
    grad(U);
}

